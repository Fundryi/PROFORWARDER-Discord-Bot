# Bot Token (Required)
BOT_TOKEN=TOKEN_HERE

# ─── Bot Behavior ─────────────────────────────────────────────────
DEBUG_MODE=false
FORWARD_BOT_MESSAGES=true
USE_SLICE_FORMAT_CONVERTER=true
USE_AI_FORMAT_CONVERTER=false

# ─── Startup Log Maintenance ──────────────────────────────────────
# Background validation/cleanup of message_logs on startup
STARTUP_LOG_MAINTENANCE=true
LOG_RETENTION_DAYS=180
LOG_RETENTION_ACTION=skip

# ─── Command UI ───────────────────────────────────────────────────
# Slash command UI (/proforwarder)
COMMAND_UI_ENABLED=true
# Comma-separated Discord role IDs allowed to use the command (empty = everyone)
COMMAND_UI_ALLOWED_ROLE_IDS=

# ─── AI Provider API Keys ─────────────────────────────────────────

# Google Gemini 2.0 Flash Preview (🟢 FREE) - MAIN PROVIDER
# Best for: High-quality AI translations with context understanding
# FREE during preview period - see: https://ai.google.dev/gemini-api/docs/pricing
# Get your FREE API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp
AI_TRANSLATION_PROVIDER=gemini

# Google Translate Configuration (🟡 FREEMIUM - Free tier: 500,000 chars/month) - FALLBACK
# Best for: Fast, reliable fallback translations
# Get your API key from: https://cloud.google.com/translate/pricing
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here
GOOGLE_PROJECT_ID=your_google_cloud_project_id

# Reader Bot Configuration (Optional)
READER_BOT_ENABLED=false
READER_BOT_TOKEN=your_reader_bot_token_here

# Telegram Integration (Optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_API_URL=https://api.telegram.org
TELEGRAM_HIDE_SOURCE_HEADER=false
TELEGRAM_SMART_LINK_PREVIEWS=true

# ─── Web Admin Panel ───────────────────────────────────────────────
# Common settings (always needed when web admin is enabled)
WEB_ADMIN_ENABLED=false
WEB_ADMIN_PORT=3001
WEB_ADMIN_AUTH_MODE=local
WEB_ADMIN_SESSION_SECRET=
WEB_ADMIN_SESSION_TTL_HOURS=24
WEB_ADMIN_DEBUG=false

# ─── Local Mode (default — for self-hosted / development) ─────────
# No Discord login needed. Access granted from trusted hosts only.
# Used when WEB_ADMIN_AUTH_MODE=local
WEB_ADMIN_LOCAL_ALLOWED_HOSTS=localhost,127.0.0.1,::1
WEB_ADMIN_LOCAL_ALLOWED_IPS=

# ─── Production / OAuth Mode ──────────────────────────────────────
# Required when WEB_ADMIN_AUTH_MODE=oauth (internet-facing installs).
# Register redirect URI in Discord Developer Portal > OAuth2 > Redirects.
WEB_ADMIN_BASE_URL=
WEB_ADMIN_TRUST_PROXY=false
WEB_ADMIN_DISCORD_CLIENT_ID=
WEB_ADMIN_DISCORD_CLIENT_SECRET=
WEB_ADMIN_DISCORD_REDIRECT_URI=
WEB_ADMIN_DISCORD_SCOPES=identify guilds
WEB_ADMIN_ALLOWED_ROLE_IDS=

# ─── Security & Rate Limits (Optional) ────────────────────────────
WEB_ADMIN_SECURITY_STRICT=false
WEB_ADMIN_AUTH_RATE_LIMIT_WINDOW_MS=300000
WEB_ADMIN_AUTH_RATE_LIMIT_MAX=60
WEB_ADMIN_MUTATION_RATE_LIMIT_WINDOW_MS=60000
WEB_ADMIN_MUTATION_RATE_LIMIT_MAX=180

# ─── Docker Compose ───────────────────────────────────────────────
# Set to "tunnel" to enable Cloudflare Tunnel on docker compose up
#COMPOSE_PROFILES=tunnel

# ─── Cloudflare Tunnel (Optional) ─────────────────────────────────
# Exposes the web admin via Cloudflare Tunnel.
# Auto-provisions a named tunnel on boot if CF API token is set. No manual setup needed.
# API token needs: Account:Cloudflare Tunnel:Edit + Zone:DNS:Edit
CLOUDFLARE_TUNNEL_API_TOKEN=
CLOUDFLARE_TUNNEL_NAME=proforwarder
CLOUDFLARE_TUNNEL_SUBDOMAIN=forward
CLOUDFLARE_TUNNEL_ZONE=xen.moe
# Or provide a pre-existing tunnel token directly (skips auto-provisioning):
#CLOUDFLARE_TUNNEL_TOKEN=

# ─── Bot Invite (Code Grant Flow) ─────────────────────────────────
# Powers the "Invite Main Bot" button in the Guilds tab.
# Reuses CLIENT_ID + CLIENT_SECRET from the section above (same Discord app).
# Register this callback URL in Discord Developer Portal > OAuth2 > Redirects.
# IMPORTANT: Use the port your BROWSER sees, not the container's internal port.
#   Docker (host:8080 → container:3001): http://localhost:8080/admin/bot-invite/callback
#   No Docker / direct:                http://localhost:3001/admin/bot-invite/callback
#   Production:                        https://yourdomain.com/admin/bot-invite/callback
BOT_INVITE_REDIRECT_URI=http://localhost:8080/admin/bot-invite/callback
